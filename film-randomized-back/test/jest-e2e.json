{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "setupFiles": ["<rootDir>/setup-e2e-env.ts"],
  "testTimeout": 30000,
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
