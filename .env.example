# Environment variables example for Film Randomized

# TMDb API Key (get it from https://www.themoviedb.org/settings/api)
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Backend Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=film_randomized
DB_SYNCHRONIZE=true
DB_SSL=false

# Mailtrap Configuration (for email service)
MAILTRAP_TOKEN=your_mailtrap_token_here
MAILTRAP_SENDER_EMAIL=your_sender_email_here

# JWT Secret (minimum 256 bits / 32 characters recommended)
JWT_SECRET=your_jwt_secret_here

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# Backend Port
PORT=8000
